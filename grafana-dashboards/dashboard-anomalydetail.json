        "iconColor": "rgba(255, 0, 0, 1)",
        "name": "Nelson 1 Violations",
        "rawQuery": "SELECT   UNIX_TIMESTAMP(v.detected_at) AS time,   'Nelson 1 위반' AS title,   CONCAT(v.description, ' (측정값: ', v.value, ', 기준: ', IFNULL(v.reference_value, 'N/A'), ')') AS text,   'Nelson 1' AS tags FROM anomaly_db.violations v JOIN anomaly_db.anomalies a ON v.anomaly_id = a.id JOIN anomaly_db.equipments e ON v.equipment_id = e.id WHERE e.name = '${equipment}'   AND a.rule_name = 'NELSON_RULE_1'   AND v.detected_at BETWEEN FROM_UNIXTIME($__from/1000) AND FROM_UNIXTIME($__to/1000)",
        "showIn": "all",
        "target": {
          "limit": 100,
          "rawQuery": true,
          "query": "SELECT   UNIX_TIMESTAMP(v.detected_at) AS time,   'Nelson 1 위반' AS title,   CONCAT(v.description, ' (측정값: ', v.value, ', 기준: ', IFNULL(v.reference_value, 'N/A'), ')') AS text,   'Nelson 1' AS tags FROM anomaly_db.violations v JOIN anomaly_db.anomalies a ON v.anomaly_id = a.id JOIN anomaly_db.equipments e ON v.equipment_id = e.id WHERE e.name = '${equipment}'   AND a.rule_name = 'NELSON_RULE_1'   AND v.detected_at BETWEEN FROM_UNIXTIME($__from/1000) AND FROM_UNIXTIME($__to/1000)",
          "refId": "Nelson1"
        },
        "type": "tags"
      },
